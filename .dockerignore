# Build context excludes. Keep in sync with the Dockerfile: everything the
# image needs (backend/ packages, the root YAML config, data/tags/, and the
# frontend sources that stage 1 builds) must survive these rules.

.git
.gitignore

# Data: most of the Scryfall/EDHREC cache is dev-only weight. The image needs
# three things (see the Dockerfile): the processed pool (Git LFS), the
# precached EDHREC pages for the featured commanders, and data/tags/ (kept).
# Everything else under data/cache (prints, raw/archetype pages) is excluded.
data/cache/*
!data/cache/edhrec
data/processed/*
!data/processed/cards.jsonl

# Built inside the image by stage 1; a local copy is stale weight.
frontend/node_modules
frontend/dist

# Python local junk
**/__pycache__
**/*.py[cod]
.venv
backend/.venv
**/*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Not served by the app
experiments
docs
backend/tests
scripts

# OS / editor
.DS_Store
Thumbs.db
.vscode
.idea
